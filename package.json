{
  "private": true,
  "version": "1.1.0",
  "name": "photo-id",
  "description": "Research tool for photo identification studies.",
  "productName": "Photo ID",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crru-uk/photo-id-app.git"
  },
  "main": ".vite/build/main.js",
  "engines": {
    "node": ">=24"
  },
  "author": {
    "name": "Cetacean Research & Rescue Unit (CRRU)",
    "email": "info@crru.org.uk"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "changesets:add": "npx @changesets/cli add",
    "changesets:version": "npx @changesets/cli version && npm install --package-lock-only",
    "changesets:tag": "npx @changesets/cli tag && git push --follow-tags",
    "test": "npm run test:linting && npm run test:types && npm run test:unit",
    "test:linting": "biome check .",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "docs": "mkdocs serve",
    "test:e2e:build": "cross-env E2E=true electron-forge package",
    "test:e2e": "playwright test"
  },
