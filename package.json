    "@primer/react": "^38.33.0",
    "@sentry/electron": "^7.15.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@tanstack/react-router": "^1.170.18",
    "csv-stringify": "^6.8.1",
    "dotenv": "^17.4.2",
